<!-- Navigation -->
<nav class="navbar">
  <div class="nav-container">
    <%= link_to dashboard_path, class: "nav-logo" do %>
      <%= image_tag "sortiq250x100web.png", alt: "SortIQ Logo", class: "logo-image" %>
    <% end %>

    <!-- Desktop Navigation -->
    <div class="desktop-nav">
      <%= link_to "Jobs", jobs_path, class: "nav-link" %>
      <%= link_to "Clients", clients_path, class: "nav-link" %>
      <%= link_to "Prospects", client_prospects_path, class: "nav-link" %>
      <%= link_to "Candidates", candidates_path, class: "nav-link" %>
      <%= link_to "Settings", change_password_path, class: "nav-link" %>
      <%= button_to "Logout", logout_path, method: :delete, class: "nav-link-logout", form: { style: "display: inline;" } %>
    </div>

    <button class="nav-toggle" aria-label="Toggle navigation">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu-overlay">
  <div class="mobile-menu">
    <button class="mobile-menu-close" aria-label="Close menu">×</button>
    <nav class="mobile-nav">
      <%= link_to "Jobs", jobs_path, class: "mobile-nav-link" %>
      <%= link_to "Clients", clients_path, class: "mobile-nav-link" %>
      <%= link_to "Prospects", client_prospects_path, class: "mobile-nav-link" %>
      <%= link_to "Candidates", candidates_path, class: "mobile-nav-link" %>
      <%= link_to "Logout", logout_path, data: { turbo_method: :delete }, class: "mobile-nav-link" %>
    </nav>
  </div>
</div>
