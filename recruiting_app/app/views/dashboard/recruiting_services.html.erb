<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recruiting Services - SortIQ</title>
  <%= stylesheet_link_tag :app %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <!-- Page Header -->
  <header class="hero-consultation fade-in-section" id="main-content">
    <div class="container">
      <div class="hero-header">
        <h1>Recruiting Services</h1>
        <p class="subtitle">The following services may be utilized individually or bundled.</p>
      </div>
    </div>
  </header>

  <!-- Services Content -->
  <section class="services-content services-padding-top fade-in-section">
    <div class="container">
      <div class="hero-cta" style="margin-top: 0;">
        <!-- Managed Recruiting Card -->
        <div class="cta-card">
          <div class="cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" role="img" aria-label="Rectangle group icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 01-1.125-1.125v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-8.25zM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-2.25z" />
            </svg>
          </div>
          <h3 class="cta-title">Managed Recruiting</h3>
          <p class="cta-description">Your logo, our recruiter, collegial full life cycle recruiting effort and much more.</p>
        </div>

        <!-- Recruitment Marketing Card -->
        <div class="cta-card">
          <div class="cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" role="img" aria-label="Megaphone icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
            </svg>
          </div>
          <h3 class="cta-title">Recruitment Marketing</h3>
          <p class="cta-description">Your logo, our community engagement marketer, collegial effort involving research, marketing, and relationship building. Ideal for Niche and Specialty AI Engineer and Developer recruitment over a longer time period.</p>
        </div>

        <!-- Recruiting Research Card -->
        <div class="cta-card">
          <div class="cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" role="img" aria-label="Square stack icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3" />
            </svg>
          </div>
          <h3 class="cta-title">Recruiting Research</h3>
          <p class="cta-description">We identify the sort of people you are looking for and present it to you in a ready for recruiting spreadsheet type format for use by your team.</p>
        </div>

        <!-- Executive Search Card -->
        <div class="cta-card">
          <div class="cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" role="img" aria-label="Puzzle piece icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z" />
            </svg>
          </div>
          <h3 class="cta-title">Executive Search</h3>
          <p class="cta-description">A confidential search for your key role.</p>
        </div>

        <!-- Employer Branding Card -->
        <div class="cta-card">
          <div class="cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" role="img" aria-label="Building icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <h3 class="cta-title">Employer Branding</h3>
          <p class="cta-description">We improve how your team is presented, perceived and marketed with better career pages, social platforms, and talent engagement pathways.</p>
        </div>

        <!-- Team Optimization Card -->
        <div class="cta-card">
          <div class="cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" role="img" aria-label="Users icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="cta-title">Team Optimization</h3>
          <p class="cta-description">Team analysis, calibration and optimization for every stage that can identify and/or address challenges and opportunities.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section fade-in-section" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Get Recruiting Help For Your Job(s)</h2>
          <h3>Let's talk.</h3>
          <form action="https://formspree.io/f/movgwvpd" method="POST" class="contact-form">
            <div class="form-group">
              <label for="name" class="sr-only">Name</label>
              <input type="text" id="name" name="name" placeholder="Your Name" required>
            </div>
            <div class="form-group">
              <label for="email" class="sr-only">Email</label>
              <input type="email" id="email" name="_replyto" placeholder="Your Email" required>
            </div>
            <div class="form-group">
              <label for="message" class="sr-only">Message</label>
              <textarea id="message" name="message" rows="4" placeholder="How can we help?" required></textarea>
            </div>
            <button type="submit" class="cta-button" style="width: 100%; border: none; cursor: pointer;">Send Message</button>
          </form>
          <div class="contact-direct">
            <p>Or call us directly:</p>
            <p><a href="tel:202-330-3909">202-330-3909</a></p>
            <p><a href="mailto:email@sortiq.com">email@sortiq.com</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/animations.js" defer></script>
  <script src="/js/main.js" defer></script>
</body>
</html>
